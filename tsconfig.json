{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@chain-lens/*": ["./challenge-1-chain-lens/src/*"],
      "@coin-smith/*": ["./challenge-2-coin-smith/src/*"],
      "@sherlock/*": ["./challenge-3-sherlock/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "challenge-1-chain-lens/web",
    "challenge-1-chain-lens/tests",
    "challenge-1-chain-lens/vitest.config.ts",
    "challenge-2-coin-smith/web",
    "challenge-2-coin-smith/tests",
    "challenge-2-coin-smith/vitest.config.ts",
    "challenge-3-sherlock/web",
    "challenge-3-sherlock/test",
    "challenge-3-sherlock/vitest.config.ts"
  ]
}
